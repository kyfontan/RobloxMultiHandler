# Default: treat as text, normalize to LF in the repo, and check out as LF.
# Matching the working copy (already LF) means no conversion -> no warnings.
* text=auto eol=lf

# Windows batch files genuinely want CRLF in the working tree.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never touch their bytes.
*.ico  binary
*.png  binary
*.jpg  binary
*.exe  binary
*.res  binary
*.o    binary
*.a    binary
